{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "<YOUR_CONNECTION_STRING_HERE>"
  },
  "Jwt": {
    "Key": "<SET_VIA_USER_SECRETS_OR_ENV_VAR>",
    "Issuer": "ShopBackend",
    "Audience": "ShopFrontend",
    "ExpireMinutes": 60
  },
  "AllowedHosts": "*"
}